# ── Client environment variables (prefix VITE_) ───────────────────────────

# Backend API server URL (leave empty for dev direct-call fallback)
VITE_API_URL=https://your-server.railway.app

# Supabase (public keys only — anon key is safe to expose)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# App
VITE_APP_TITLE=타닥타닥
